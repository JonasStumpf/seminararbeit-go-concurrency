{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Current File",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Advocate: Analysis (launch)",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${workspaceFolder}/ADVOCATE/advocate/advocate",
      "args": [
        "analysis",
        "-path",
        "${workspaceFolder}/ADVOCATE/doc/examples/deadlocks/",
        "-exec",
        "TestBasicLockdep"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Advocate: Run Current File (prompt)",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${workspaceFolder}/ADVOCATE/advocate/advocate",
      "args": [
        "${input:advocateMode}",
        "-path",
        "${fileDirname}",
        "${input:advocateMain}",
        "-exec",
        "${input:advocateExec}"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ],
  "inputs": [
    {
      "id": "advocateMode",
      "type": "pickString",
      "description": "Select ADVOCATE mode",
      "options": ["analysis", "record", "replay", "fuzzing"],
      "default": "analysis"
    },
    {
      "id": "advocateExec",
      "type": "promptString",
      "description": "Test or prog name to execute (leave empty for none)",
      "default": "TestBasicLockdep"
    }
  ,
    {
      "id": "advocateMain",
      "type": "pickString",
      "description": "Pass -main flag for running main instead of tests",
      "options": ["", "-main"],
      "default": ""
    }
  ]
}